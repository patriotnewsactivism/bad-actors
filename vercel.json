{
  "buildCommand": "npm run build && node prerender.mjs",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/track/:slug", "destination": "/track/:slug/index.html" },
    { "source": "/tracks", "destination": "/tracks/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/((?!assets|track|tracks|about|api|sitemap|robots|bad-actors|site\\.webmanifest|favicon).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "no-referrer-when-downgrade" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
